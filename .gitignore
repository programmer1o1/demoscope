# Build output
/target

# Generated HTML visualizations (but keep the embedded Rust templates + the
# WASM drag-and-drop UI page so the in-browser build can be hosted as-is).
# src/*.html are include_str!'d at compile time, so they MUST stay tracked.
*.html
!src/template.html
!src/dual_template.html
!web/index.html

# WASM build artifacts — regenerated by scripts/build-wasm.sh and the pages
# CI workflow, so they're built fresh rather than committed.
/web/*.wasm
/web/*.js
/web/*.d.ts

# Test data (large binary game files — keep locally, don't publish)
DEMOS TESTING/

# macOS
.DS_Store

# Editor artifacts
*.swp
*.swo
.vscode/
